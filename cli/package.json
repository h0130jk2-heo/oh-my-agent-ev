{
  "name": "heo-agent",
  "version": "4.22.4",
  "description": "Personal multi-agent workflow harness with evaluator extension",
  "type": "module",
  "bin": {
    "oh-my-ag": "./bin/cli.js",
    "oma": "./bin/cli.js"
  },
  "files": [
    "bin"
  ],
  "keywords": [
    "agent",
    "workflow",
    "claude-code",
    "multi-agent"
  ],
  "author": "h0130jk2-heo",
  "contributors": [
    "our.first.fluke <our.first.fluke@gmail.com>",
    "gracefullight <gracefullight.dev@gmail.com>",
    "gahyun-git <go4it.gh@gmail.com>"
  ],
  "license": "MIT",
  "scripts": {
    "sync:readme": "node ./scripts/sync-readme.mjs",
    "build": "bun run sync:readme && bun build cli.ts --outfile bin/cli.js --target node --minify",
    "dev": "bun run cli.ts",
    "lint": "biome check --write --unsafe .",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "p-map": "^7.0.4",
    "picocolors": "^1.1.1",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "^1.3.10",
    "@types/ws": "^8.18.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/h0130jk2-heo/oh-my-agent-ev"
  },
  "antigravity": {
    "skillsPath": ".agents/skills",
    "skills": [
      "oma-brainstorm",
      "oma-coordination",
      "oma-pm",
      "oma-frontend",
      "oma-backend",
      "oma-db",
      "oma-mobile",
      "oma-qa",
      "oma-debug",
      "oma-orchestrator",
      "oma-dev-workflow",
      "oma-tf-infra",
      "oma-commit"
    ]
  }
}
